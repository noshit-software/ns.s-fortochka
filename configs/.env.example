# Fortochka server configuration
# Copy to .env and fill in before running setup-server.sh
# All values have sensible defaults — you can run setup with an empty .env

# SNI domain for Reality (must be from sni-whitelist.txt)
# Default: microsoft.com
SNI_DOMAIN=microsoft.com

# 3x-ui panel port (random high port recommended)
# Default: auto-generated
PANEL_PORT=

# 3x-ui panel credentials
# Default: auto-generated (printed at end of setup)
PANEL_USERNAME=
PANEL_PASSWORD=

# Client UUID (shared across all servers for this user)
# Default: auto-generated
CLIENT_UUID=

# Reality keypair (leave blank to auto-generate)
# If you want multiple servers to share the same keypair, set these
REALITY_PRIVATE_KEY=
REALITY_PUBLIC_KEY=

# WebSocket fallback port
# Default: auto-generated
WS_PORT=

# Server display name (used in client config names)
SERVER_NAME=fortochka-1
